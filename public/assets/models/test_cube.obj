# Simple test cube - 8 vertices, 12 triangles
# Centered at origin, extends from -1 to 1 on all axes

v  1.0  1.0 -1.0
v  1.0 -1.0 -1.0
v  1.0  1.0  1.0
v  1.0 -1.0  1.0
v -1.0  1.0 -1.0
v -1.0 -1.0 -1.0
v -1.0  1.0  1.0
v -1.0 -1.0  1.0

vn  0.0  1.0  0.0
vn  0.0  0.0  1.0
vn -1.0  0.0  0.0
vn  0.0 -1.0  0.0
vn  1.0  0.0  0.0
vn  0.0  0.0 -1.0

# Top
f 1//1 5//1 7//1
f 1//1 7//1 3//1
# Front
f 4//2 3//2 7//2
f 4//2 7//2 8//2
# Left
f 8//3 7//3 5//3
f 8//3 5//3 6//3
# Bottom
f 6//4 2//4 4//4
f 6//4 4//4 8//4
# Right
f 2//5 1//5 3//5
f 2//5 3//5 4//5
# Back
f 6//6 5//6 1//6
f 6//6 1//6 2//6
